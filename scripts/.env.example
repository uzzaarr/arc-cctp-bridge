# Copy this file to `.env` and fill it in.
# NEVER commit the real `.env` file.

# USE A FRESH BURNER WALLET ONLY.
# Fund it on Base with a little USDC + ETH for gas.

PRIVATE_KEY=0x_your_burner_private_key_here

# Optional: where the USDC should land on Arc.
# Defaults to the same address as the burner if left empty.
RECIPIENT_ADDRESS=
